{
    "name": "%NAME%",
    "description": "%DESCRIPTION%",
    "keywords": [
        "php",
        "symfony"
    ],
    "repository": "%REPOSITORY%",
    "scripts": {
        "dokku": {
            "predeploy": "bin/console importmap:install && bin/console asset-map:compile && bin/console  secrets:decrypt-to-local --force && bin/console doctrine:migrations:migrate -n --allow-no-migration",
            "postdeploy": "bin/console about"
        }
    },
    "env": {
        "SECRET_TOKEN": {
            "description": "A secret key for verifying the integrity of signed cookies.",
            "value": "secret"
        },
        "WEB_CONCURRENCY": {
            "description": "The number of web processes to run.",
            "value": "5"
        },
        "APP_ENV": {
            "description": "Symfony environment.",
            "value": "prod"
        },
        "APP_DEBUG": {
            "description": "Symfony debug flag.",
            "value": "0"
        }
    },
    "image": "gliderlabs/herokuish",
    "addons": [
        "dokku-postgres",
        "dokku-redis"
    ],
    "buildpacks": [
        {
            "url": "https://github.com/heroku/heroku-buildpack-php.git"
        }
    ]
}
